<?xml version="1.0"?>
<config version="10.1.0" urldb="paloaltonetworks">
  <devices>
    <entry name="localhost.localdomain">
      <deviceconfig>
        <system>
          <hostname>pa-fw-01</hostname>
        </system>
      </deviceconfig>
      <vsys>
        <entry name="vsys1">
          <address>
            <entry name="Internal-Net">
              <ip-netmask>10.0.1.0/24</ip-netmask>
              <description>Internal network segment</description>
            </entry>
            <entry name="Server-DMZ">
              <ip-netmask>10.0.50.0/24</ip-netmask>
              <description>DMZ server network</description>
            </entry>
          </address>
          <service>
            <entry name="service-https">
              <protocol>
                <tcp>
                  <port>443</port>
                </tcp>
              </protocol>
              <description>HTTPS service</description>
            </entry>
          </service>
          <rulebase>
            <security>
              <rules>
                <entry name="Allow-Internal-Web">
                  <from>
                    <member>trust</member>
                  </from>
                  <to>
                    <member>dmz</member>
                  </to>
                  <source>
                    <member>Internal-Net</member>
                  </source>
                  <destination>
                    <member>Server-DMZ</member>
                  </destination>
                  <service>
                    <member>service-https</member>
                  </service>
                  <action>allow</action>
                  <log-start>no</log-start>
                  <log-end>yes</log-end>
                  <description>Allow internal users to access DMZ web servers</description>
                </entry>
                <entry name="Deny-All">
                  <from>
                    <member>any</member>
                  </from>
                  <to>
                    <member>any</member>
                  </to>
                  <source>
                    <member>any</member>
                  </source>
                  <destination>
                    <member>any</member>
                  </destination>
                  <service>
                    <member>any</member>
                  </service>
                  <action>deny</action>
                  <log-start>no</log-start>
                  <log-end>yes</log-end>
                </entry>
              </rules>
            </security>
            <nat>
              <rules>
                <entry name="NAT-Internal-Outbound">
                  <source>
                    <member>Internal-Net</member>
                  </source>
                  <destination>
                    <member>any</member>
                  </destination>
                  <service>any</service>
                  <nat-type>ipv4</nat-type>
                  <source-translation>
                    <dynamic-ip-and-port>
                      <translated-address>
                        <member>203.0.113.10</member>
                      </translated-address>
                    </dynamic-ip-and-port>
                  </source-translation>
                </entry>
              </rules>
            </nat>
          </rulebase>
          <zone>
            <entry name="trust">
              <network>
                <member>ethernet1/1</member>
              </network>
            </entry>
            <entry name="dmz">
              <network>
                <member>ethernet1/2</member>
              </network>
            </entry>
          </zone>
        </entry>
      </vsys>
      <network>
        <interface>
          <ethernet>
            <entry name="ethernet1/1">
              <layer3>
                <ip>
                  <entry name="10.0.1.1/24"/>
                </ip>
                <zone>
                  <member>trust</member>
                </zone>
              </layer3>
            </entry>
            <entry name="ethernet1/2">
              <layer3>
                <ip>
                  <entry name="10.0.50.1/24"/>
                </ip>
                <zone>
                  <member>dmz</member>
                </zone>
              </layer3>
            </entry>
          </ethernet>
        </interface>
      </network>
    </entry>
  </devices>
</config>
